# ============================
# RENEWMRV - Configuration
# ============================

# Domaine
DOMAIN=votre-domaine.com
FRONTEND_URL=https://votre-domaine.com
NEXT_PUBLIC_API_URL=https://votre-domaine.com/api

# Database PostgreSQL
POSTGRES_DB=renewmrv
POSTGRES_USER=renewmrv_user
POSTGRES_PASSWORD=CHANGEZ_CE_MOT_DE_PASSE_FORT
DATABASE_URL=postgresql://renewmrv_user:CHANGEZ_CE_MOT_DE_PASSE_FORT@postgres:5432/renewmrv

# Redis
REDIS_URL=redis://redis:6379

# JWT (générer avec: openssl rand -hex 64)
JWT_SECRET=CHANGEZ_CE_SECRET_JWT_64_CHARS_MINIMUM
JWT_REFRESH_SECRET=CHANGEZ_CE_REFRESH_SECRET_64_CHARS_MINIMUM
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email (SMTP pour les rapports)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre@email.com
SMTP_PASS=votre_mot_de_passe_app

# Carbon Market (optionnel - prix live)
CARBON_MARKET_API_KEY=
