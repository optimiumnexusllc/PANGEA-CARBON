generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  ANALYST
  AUDITOR
  CLIENT
  VIEWER
}

enum ProjectType {
  SOLAR
  WIND
  HYDRO
  BIOMASS
  HYBRID
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  MONITORING
  VERIFIED
  CREDITED
  ARCHIVED
}

enum ReportStatus {
  PENDING
  GENERATING
  READY
  FAILED
}

enum PlanTier {
  FREE
  STARTER
  PRO
  ENTERPRISE
  CUSTOM
}

enum OrgStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  CHURNED
}

model Organization {
  id               String       @id @default(cuid())
  name             String
  slug             String       @unique
  domain           String?
  plan             PlanTier     @default(TRIAL)
  status           OrgStatus    @default(TRIAL)
  maxProjects      Int          @default(5)
  maxMW            Float        @default(100)
  maxUsers         Int          @default(3)
  stripeCustomerId String?
  stripeSubId      String?
  trialEndsAt      DateTime?
  billingEmail     String?
  country          String?
  logoUrl          String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  users            User[]
  projects         Project[]
  invoices         Invoice[]
  featureAccess    OrgFeature[]
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  password       String
  name           String
  role           Role          @default(ANALYST)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  isActive       Boolean       @default(false)
  emailVerified  Boolean       @default(false)
  verifyToken    String?       @unique
  verifyExpires  DateTime?
  lastLoginAt    DateTime?
  loginCount     Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  projects       Project[]
  reports        Report[]
  auditLogs      AuditLog[]
  apiKeys        ApiKey[]
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  name       String
  keyHash    String    @unique
  keyPrefix  String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  encrypted   Boolean  @default(false)
  category    String   @default("general")
  description String?
  updatedBy   String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model FeatureFlag {
  id          String       @id @default(cuid())
  key         String       @unique
  name        String
  description String?
  enabled     Boolean      @default(false)
  rolloutPct  Int          @default(100)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  orgAccess   OrgFeature[]
}

model OrgFeature {
  id        String       @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id])
  featureId String
  feature   FeatureFlag  @relation(fields: [featureId], references: [id])
  enabled   Boolean      @default(true)
  createdAt DateTime     @default(now())

  @@unique([orgId, featureId])
}

model Invoice {
  id              String       @id @default(cuid())
  orgId           String
  org             Organization @relation(fields: [orgId], references: [id])
  stripeInvoiceId String?
  amount          Float
  currency        String       @default("usd")
  status          String       @default("pending")
  plan            PlanTier
  periodStart     DateTime
  periodEnd       DateTime
  paidAt          DateTime?
  createdAt       DateTime     @default(now())
}

model Project {
  id             String        @id @default(cuid())
  name           String
  description    String?
  type           ProjectType
  status         ProjectStatus @default(DRAFT)
  country        String
  countryCode    String
  latitude       Float?
  longitude      Float?
  installedMW    Float
  startDate      DateTime
  endDate        DateTime?
  methodology    String        @default("ACM0002")
  standard       String        @default("Verra VCS")
  baselineEF     Float
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  readings       EnergyReading[]
  mrvRecords     MRVRecord[]
  reports        Report[]
  auditLogs      AuditLog[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([country])
  @@index([status])
  @@index([organizationId])
}

model EnergyReading {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  periodStart     DateTime
  periodEnd       DateTime
  energyMWh       Float
  peakPowerMW     Float?
  availabilityPct Float?
  source          String   @default("MANUAL")
  verified        Boolean  @default(false)
  notes           String?
  createdAt       DateTime @default(now())

  @@index([projectId])
  @@index([periodStart])
}

model MRVRecord {
  id                 String    @id @default(cuid())
  projectId          String
  project            Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  year               Int
  totalEnergyMWh     Float
  baselineEF         Float
  emissionReductions Float
  leakageDeduction   Float     @default(0)
  netCarbonCredits   Float
  marketPriceUSD     Float     @default(12.0)
  revenueUSD         Float
  verifiedAt         DateTime?
  verifiedBy         String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([projectId, year])
  @@index([projectId])
}

model Report {
  id          String       @id @default(cuid())
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id])
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  type        String
  year        Int
  status      ReportStatus @default(PENDING)
  filePath    String?
  fileSize    Int?
  generatedAt DateTime?
  createdAt   DateTime     @default(now())

  @@index([projectId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])
  action    String
  entity    String
  entityId  String
  before    Json?
  after     Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([projectId])
  @@index([createdAt])
  @@index([action])
}
