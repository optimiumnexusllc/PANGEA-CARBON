generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  ANALYST
  AUDITOR
  CLIENT
  VIEWER
}

enum ProjectType {
  SOLAR
  WIND
  HYDRO
  BIOMASS
  HYBRID
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  MONITORING
  VERIFIED
  CREDITED
  ARCHIVED
}

enum ReportStatus {
  PENDING
  GENERATING
  READY
  FAILED
}

enum PlanTier {
  FREE
  TRIAL
  STARTER
  PRO
  ENTERPRISE
  CUSTOM
}

enum OrgStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  CHURNED
}

model Organization {
  id               String       @id @default(cuid())
  name             String
  slug             String       @unique
  domain           String?
  plan             PlanTier     @default(TRIAL)
  status           OrgStatus    @default(TRIAL)
  maxProjects      Int          @default(5)
  maxMW            Float        @default(100)
  maxUsers         Int          @default(3)
  stripeCustomerId String?
  stripeSubId      String?
  trialEndsAt      DateTime?
  billingEmail     String?
  country          String?
  logoUrl          String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  users            User[]
  projects         Project[]
  invoices         Invoice[]
  featureAccess    OrgFeature[]
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  password       String
  name           String
  role           Role          @default(ANALYST)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  isActive       Boolean       @default(false)
  emailVerified  Boolean       @default(false)
  verifyToken    String?       @unique
  verifyExpires  DateTime?
  lastLoginAt    DateTime?
  loginCount     Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  projects       Project[]
  reports        Report[]
  auditLogs      AuditLog[]
  marketplaceOrders MarketplaceOrder[]
  apiKeys        ApiKey[]
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  name       String
  keyHash    String    @unique
  keyPrefix  String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  encrypted   Boolean  @default(false)
  category    String   @default("general")
  description String?
  updatedBy   String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model FeatureFlag {
  id          String       @id @default(cuid())
  key         String       @unique
  name        String
  description String?
  enabled     Boolean      @default(false)
  rolloutPct  Int          @default(100)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  orgAccess   OrgFeature[]
}

model OrgFeature {
  id        String       @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id])
  featureId String
  feature   FeatureFlag  @relation(fields: [featureId], references: [id])
  enabled   Boolean      @default(true)
  createdAt DateTime     @default(now())

  @@unique([orgId, featureId])
}

model Invoice {
  id              String       @id @default(cuid())
  orgId           String
  org             Organization @relation(fields: [orgId], references: [id])
  stripeInvoiceId String?
  amount          Float
  currency        String       @default("usd")
  status          String       @default("pending")
  plan            PlanTier
  periodStart     DateTime
  periodEnd       DateTime
  paidAt          DateTime?
  createdAt       DateTime     @default(now())
}

model Project {
  id             String        @id @default(cuid())
  name           String
  description    String?
  type           ProjectType
  status         ProjectStatus @default(DRAFT)
  country        String
  countryCode    String
  latitude       Float?
  longitude      Float?
  installedMW    Float
  startDate      DateTime
  endDate        DateTime?
  methodology    String        @default("ACM0002")
  standard       String        @default("Verra VCS")
  baselineEF     Float
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  readings       EnergyReading[]
  mrvRecords     MRVRecord[]
  reports        Report[]
  auditLogs         AuditLog[]
  itmoRecords       ITMORecord[]
  sdgScores         SDGScore[]
  satelliteReadings SatelliteReading[]
  iotReadings       IoTReading[]
  corsiaEligibility CORSIAEligibility?
  creditIssuances   CreditIssuance[]
  baselineAssessments  BaselineAssessment[]
  certification        ProjectCertification?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([country])
  @@index([status])
  @@index([organizationId])
}

model EnergyReading {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  periodStart     DateTime
  periodEnd       DateTime
  energyMWh       Float
  peakPowerMW     Float?
  availabilityPct Float?
  source          String   @default("MANUAL")
  verified        Boolean  @default(false)
  notes           String?
  createdAt       DateTime @default(now())

  @@index([projectId])
  @@index([periodStart])
}

model MRVRecord {
  id                 String    @id @default(cuid())
  projectId          String
  project            Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  year               Int
  totalEnergyMWh     Float
  baselineEF         Float
  emissionReductions Float
  leakageDeduction   Float     @default(0)
  netCarbonCredits   Float
  marketPriceUSD     Float     @default(12.0)
  revenueUSD         Float
  verifiedAt         DateTime?
  verifiedBy         String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([projectId, year])
  @@index([projectId])
}

model Report {
  id          String       @id @default(cuid())
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id])
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  type        String
  year        Int
  status      ReportStatus @default(PENDING)
  filePath    String?
  fileSize    Int?
  generatedAt DateTime?
  createdAt   DateTime     @default(now())

  @@index([projectId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])
  action    String
  entity    String
  entityId  String
  before    Json?
  after     Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([projectId])
  @@index([createdAt])
  @@index([action])
}

// ─── ARTICLE 6 / ITMO ─────────────────────────────────────────────────────
model ITMORecord {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id])
  year            Int
  hostCountry     String
  buyingCountry   String
  itmoQuantity    Float    // tCO2e autorisées comme ITMO
  pricePerTonne   Float    // $/tCO2e
  totalValueUSD   Float
  authorizationRef String? // Référence autorisation souveraine
  correspondingAdj Boolean @default(false) // Ajustement correspondant appliqué
  status          String   @default("PENDING") // PENDING AUTHORIZED TRANSFERRED
  transferDate    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([projectId])
}

// ─── GOLD STANDARD SDG SCORING ────────────────────────────────────────────
model SDGScore {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  year        Int
  // 17 SDG scores (0-10 chacun)
  sdg1  Float @default(0) // No poverty
  sdg2  Float @default(0) // Zero hunger
  sdg3  Float @default(0) // Good health
  sdg4  Float @default(0) // Quality education
  sdg5  Float @default(0) // Gender equality
  sdg6  Float @default(0) // Clean water
  sdg7  Float @default(0) // Clean energy
  sdg8  Float @default(0) // Decent work
  sdg9  Float @default(0) // Industry innovation
  sdg10 Float @default(0) // Reduced inequalities
  sdg11 Float @default(0) // Sustainable cities
  sdg12 Float @default(0) // Responsible consumption
  sdg13 Float @default(0) // Climate action
  sdg14 Float @default(0) // Life below water
  sdg15 Float @default(0) // Life on land
  sdg16 Float @default(0) // Peace justice
  sdg17 Float @default(0) // Partnerships
  totalScore      Float    @default(0)
  premiumUSD      Float    @default(0) // Premium $/tCO2e généré
  gsStarRating    Int      @default(0) // 0-5 étoiles Gold Standard
  jobsCreated     Int      @default(0)
  householdsElectrified Int @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([projectId, year])
  @@index([projectId])
}

// ─── dMRV — DIGITAL MRV ENGINE ────────────────────────────────────────────
model SatelliteReading {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id])
  captureDate   DateTime
  satellite     String   @default("SENTINEL-2") // SENTINEL-2 LANDSAT-9 MODIS
  cloudCoverPct Float    @default(0)
  ndviScore     Float?   // Vegetation index (for biomass)
  irradianceMWh Float?   // Irradiance estimée (MWh/m²)
  estimatedMWh  Float?   // Production estimée via satellite
  actualMWh     Float?   // Production mesurée (si disponible)
  confidence    Float    @default(0.85) // 0-1 confidence score
  rawData       Json?    // Données brutes satellite
  verified      Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([projectId])
  @@index([captureDate])
}

model IoTReading {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  deviceId    String
  deviceType  String   // PYRANOMETER ANEMOMETER IRRADIANCE METER POWER_ANALYZER
  timestamp   DateTime
  value       Float
  unit        String   // W/m2 m/s kWh kW
  quality     String   @default("GOOD") // GOOD SUSPECT BAD
  createdAt   DateTime @default(now())

  @@index([projectId])
  @@index([deviceId])
  @@index([timestamp])
}

// ─── CORSIA ELIGIBILITY ───────────────────────────────────────────────────
model CORSIAEligibility {
  id                  String   @id @default(cuid())
  projectId           String   @unique
  project             Project  @relation(fields: [projectId], references: [id])
  eligible            Boolean  @default(false)
  eligibilityScore    Float    @default(0) // 0-100
  phase               String?  // CORSIA Phase (PILOT 2021-2023, PHASE1 2024-2026...)
  verraApproved       Boolean  @default(false)
  gsApproved          Boolean  @default(false)
  additionalityMet    Boolean  @default(false)
  permanenceMet       Boolean  @default(false)
  noDoubleCounting    Boolean  @default(false)
  failureReasons      String[] @default([])
  estimatedPremiumUSD Float    @default(0)
  lastChecked         DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([eligible])
}

// ─── BLOCKCHAIN CREDIT REGISTRY ──────────────────────────────────────────
model CreditIssuance {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id])
  vintage         Int      // Année de génération
  quantity        Float    // tCO2e
  standard        String   // VERRA_VCS GOLD_STANDARD ARTICLE6 CORSIA
  serialFrom      String   // Numéro de série début
  serialTo        String   // Numéro de série fin
  status          String   @default("ISSUED") // ISSUED RETIRED TRANSFERRED CANCELLED
  previousHash    String   // Hash du bloc précédent (blockchain)
  blockHash       String   @unique // SHA-256 de ce bloc
  blockNumber     Int      // Numéro séquentiel du bloc
  merkleRoot      String?  // Merkle root des données
  buyerEntity     String?
  retiredFor      String?  // Raison de la retraite
  transferredTo   String?
  issuedAt        DateTime @default(now())
  retiredAt       DateTime?
  metadata        Json?

  @@index([projectId])
  @@index([status])
  @@index([vintage])
}

// ─── AI BASELINE SETTER ──────────────────────────────────────────────────
model BaselineAssessment {
  id                  String   @id @default(cuid())
  projectId           String
  project             Project  @relation(fields: [projectId], references: [id])
  assessmentDate      DateTime @default(now())
  methodology         String   // ACM0002 AMS-I.D etc
  baselineEF          Float    // tCO2/MWh calculé
  confidenceInterval  Float    @default(0.9) // 90% CI
  dataSourcesUsed     String[] // UNFCCC IEA NATIONAL_GRID SATELLITE
  satelliteValidated  Boolean  @default(false)
  aiAnalysis          String?  // Analyse textuelle par Claude
  gridEmissionsData   Json?    // Données grille utilisées
  adjustmentFactor    Float    @default(1.0)
  recommendedActions  String[] @default([])
  validUntil          DateTime
  createdAt           DateTime @default(now())

  @@index([projectId])
}

// ─── 2FA TOTP ─────────────────────────────────────────────────────────────
model TwoFactorAuth {
  id          String   @id @default(cuid())
  userId      String   @unique
  secret      String   // Chiffré AES-256
  enabled     Boolean  @default(false)
  backupCodes String[] // Codes de secours hashés
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProjectCertification {
  id              String   @id @default(cuid())
  projectId       String   @unique
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tier            String   // VERIFIED | CERTIFIED | ELITE | ELITE_CORSIA
  hash            String   @unique // SHA256 pour vérification publique
  standards       String[] // VERRA, GOLD_STANDARD, ACMI, CORSIA, etc.
  acmiCompliant   Boolean  @default(false)
  corsiaEligible  Boolean  @default(false)
  oddScore        Int      @default(0) // Score ODD 0-100
  auditorName     String?
  auditorUrl      String?
  issuedAt        DateTime @default(now())
  expiresAt       DateTime
  revokedAt       DateTime?
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@index([hash])
  @@index([projectId])
}

// ─── CARBON MARKETPLACE ORDERS ──────────────────────────────────────────────
model MarketplaceOrder {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  listingId       String   // CreditIssuance.id
  quantity        Float    // tCO2e
  pricePerTonne   Float    // $/tCO2e
  subtotal        Float    // quantity * price
  pangeaFee       Float    // 2.5%
  total           Float    // subtotal + fee
  orderType       String   @default("MARKET") // MARKET | LIMIT
  buyerNote       String?
  status          String   @default("PENDING") // PENDING | PAYMENT_PENDING | PAID | SETTLED | RETIRED | CANCELLED | REFUNDED
  paymentMethod   String?  // STRIPE_CARD | STRIPE_INVOICE | WIRE_TRANSFER
  stripeSessionId String?
  stripePaymentIntentId String?
  stripeInvoiceId String?
  stripeInvoiceUrl String?
  stripeReceiptUrl String?
  paidAt          DateTime?
  settledAt       DateTime?
  retiredAt       DateTime?
  invoicePdf      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([listingId])
  @@index([status])
}
